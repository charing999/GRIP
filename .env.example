PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 보안
HMAC_SECRET=
MAX_DISTANCE_METERS=100

# Redis
REDIS_URL=redis://localhost:6379

# 로컬 AI (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4
AI_ANALYSIS_INTERVAL_MINUTES=5
GEMMA_API_KEY=
GEMMA_API_URL=
DISABLE_AI=false
